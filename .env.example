FLASK_APP=run.py
FLASK_DEBUG=True
SECRET_KEY=replace-with-a-random-secret

DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5432/mba_ethics

# Optional Microsoft Entra ID login.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/microsoft/callback

# SMTP mail delivery. Required for assessor/supervisor onboarding and invitations.
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_TIMEOUT=5
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Optional shorthand used by config.py when MAIL_USERNAME/MAIL_PASSWORD are blank.
EMAIL=
EMAIL_CODE=
